# Port the app listens on (plain HTTP; TLS is terminated by the reverse proxy)
PORT=3200

# Root directory for all runtime data (SQLite DB, photos, watermark)
DATA_DIR=/opt/sites/gallery/data

# 64 random characters; used to sign/encrypt all session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# bcrypt hash of the admin password.
# Generate with: node scripts/hash-password.mjs 'your-password'
ADMIN_PASSWORD_HASH=

# Site name shown in headers/titles (baked in at build time)
NEXT_PUBLIC_SITE_NAME="Kristian Buriasco"

# Public base URL, used to build share links and WebAuthn origin checks.
# Must be the real https origin visitors use (e.g. https://gallery.example.com).
BASE_URL=https://gallery.kristianburiasco.it

# Optional WebAuthn RP ID override (defaults to the host of BASE_URL).
# RP_ID=gallery.kristianburiasco.it
