# Copy to .env and fill in. For Docker, these map to the compose environment.

# Port the app listens on (plain HTTP; put a reverse proxy in front for TLS).
PORT=3200

# Root directory for all runtime data (SQLite DB, photos, watermarks, backups).
# In Docker this is the mounted volume, default /data.
DATA_DIR=./data

# REQUIRED in production. 64 random hex chars; signs/encrypts session cookies.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=

# bcrypt hash of the admin password. If left empty, a temporary password is
# generated and printed to the logs on first run (set this to keep it stable).
# Generate with:  node scripts/hash-password.mjs 'your-password'
ADMIN_PASSWORD_HASH=

# Public base URL visitors use — real https origin in production. Used for
# share links and as the WebAuthn/passkey origin + RP ID.
# e.g. https://gallery.example.com
BASE_URL=http://localhost:3200

# Site name shown in headers/titles.
NEXT_PUBLIC_SITE_NAME="Albm"

# Optional: override the WebAuthn RP ID (defaults to the host of BASE_URL).
# RP_ID=gallery.example.com

# Optional: set to 1 to disable the daily GitHub release-update check
# (the app's only outbound request).
DISABLE_UPDATE_CHECK=
